# Flask Configuration
FLASK_ENV=development
FLASK_APP=wsgi.py

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_web_app_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_web_app_test

# Security Keys
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File Upload Configuration
# ALLOWED_EXTENSIONS=pdf,doc,docx,txt,jpg,png,jpeg
# UPLOAD_FOLDER=uploads

# Notification Settings
# WHATSAPP_NOTIFICATIONS_ENABLED=false
# EMAIL_NOTIFICATIONS_ENABLED=true
# INAPP_NOTIFICATIONS_ENABLED=true

# WhatsApp Configuration (if enabled)
# WHATSAPP_API_KEY=your_whatsapp_api_key
# WHATSAPP_PHONE_NUMBER=your_phone_number

# Email Configuration (if enabled)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@company.com
